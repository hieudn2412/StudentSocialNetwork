@{
    ViewData["Title"] = "Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account-settings.css" asp-append-version="true" />
}

<div id="account-page" class="container py-4 account-page" data-page="profile">
    <div class="row g-4">
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="profile-avatar-wrap mx-auto mb-3">
                        <img id="profile-avatar-preview" class="profile-avatar" src="" alt="Avatar" />
                    </div>
                    <h1 id="profile-display-name" class="h5 mb-1">My profile</h1>
                    <p id="profile-display-email" class="text-muted small mb-3">-</p>

                    <div class="d-grid gap-2">
                        <input id="profile-avatar-file" type="file" accept="image/*" class="d-none" />
                        <button id="profile-avatar-upload-btn" type="button" class="btn btn-outline-primary btn-sm">Upload avatar</button>
                    </div>

                    <hr class="my-3" />

                    <dl class="row text-start mb-0 small">
                        <dt class="col-5 text-muted">Provider</dt>
                        <dd id="profile-provider" class="col-7 mb-2">-</dd>

                        <dt class="col-5 text-muted">Created</dt>
                        <dd id="profile-created-at" class="col-7 mb-2">-</dd>

                        <dt class="col-5 text-muted">Status</dt>
                        <dd id="profile-status" class="col-7 mb-2">-</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h6 mb-3">Profile details</h2>

                    <form id="profile-form" class="vstack gap-3">
                        <div>
                            <label class="form-label" for="profile-username">Username</label>
                            <input id="profile-username" class="form-control" type="text" maxlength="100" required />
                        </div>

                        <div>
                            <label class="form-label" for="profile-email">Email</label>
                            <input id="profile-email" class="form-control" type="email" disabled />
                        </div>

                        <div>
                            <label class="form-label" for="profile-bio">Bio</label>
                            <textarea id="profile-bio" class="form-control" rows="4" maxlength="500" placeholder="Tell everyone about yourself"></textarea>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary">Save profile</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h6 mb-3">Connected accounts</h2>
                    <div id="profile-connected-providers" class="provider-list"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/account-settings.js" asp-append-version="true"></script>
}
