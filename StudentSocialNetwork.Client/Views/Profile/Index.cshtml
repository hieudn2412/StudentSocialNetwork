@{
    Layout = null;
}

<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Profile</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/fptsocial.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/account-settings.css" asp-append-version="true" />
</head>
<body>
<div id="account-page" class="app-shell" data-page="profile">
    <nav class="topbar">
        <div class="topbar-inner">
            <a href="/home" class="logo">
                <div class="logo-box">F</div>
                <span>FPT<span class="brand-accent">Social</span></span>
            </a>

            <div class="top-actions ms-auto">
                <a id="nav-login-link" class="btn btn-outline-primary btn-sm" href="/auth/login">Login</a>

                <div id="nav-auth-menu" class="dropdown d-none">
                    <button class="btn btn-light btn-sm dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <img id="nav-profile-avatar" class="rounded-circle" src="" alt="Avatar" width="26" height="26" />
                        <span id="nav-profile-name" class="fw-semibold">Account</span>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        <li><a class="dropdown-item" href="/profile">Profile</a></li>
                        <li><a class="dropdown-item" href="/settings">Settings</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><button id="nav-logout-button" class="dropdown-item text-danger" type="button">Logout</button></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="main-layout">
        <aside class="left-sidebar">
            <nav>
                <a href="/home" class="nav-link">
                    <span class="icon icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 10.5 12 3l9 7.5"></path><path d="M5 9.5V21h14V9.5"></path></svg>
                    </span>
                    <span>Trang chủ</span>
                </a>
                <a href="/conversations" class="nav-link">
                    <span class="icon icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    </span>
                    <span>Trò chuyện</span>
                </a>
                <a href="/profile" class="nav-link active">
                    <span class="icon icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21a8 8 0 0 0-16 0"></path><circle cx="12" cy="8" r="4"></circle></svg>
                    </span>
                    <span>Trang cá nhân</span>
                </a>
                <a href="/settings" class="nav-link">
                    <span class="icon icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M12 2v3"></path><path d="M12 19v3"></path><path d="m4.93 4.93 2.12 2.12"></path><path d="m16.95 16.95 2.12 2.12"></path><path d="M2 12h3"></path><path d="M19 12h3"></path><path d="m4.93 19.07 2.12-2.12"></path><path d="m16.95 7.05 2.12-2.12"></path></svg>
                    </span>
                    <span>Cài đặt</span>
                </a>
            </nav>
        </aside>

        <main class="page-main">
            <div class="page-wide">
                <section class="card">
                    <div class="profile-cover"></div>
                    <div class="profile-body">
                        <div class="profile-top">
                            <img id="profile-avatar-preview" class="avatar avatar-xl" src="" alt="Avatar">
                            <div class="d-flex gap-2 flex-wrap">
                                <input id="profile-avatar-file" type="file" accept="image/*" class="d-none" />
                                <button id="profile-avatar-upload-btn" class="btn btn-outline" type="button">Đổi ảnh đại diện</button>
                                <button class="btn btn-primary" type="button" data-open-modal="edit-profile">Chỉnh sửa trang cá nhân</button>
                            </div>
                        </div>

                        <div>
                            <h1 id="profile-display-name">My profile</h1>
                            <p id="profile-display-email" class="subtitle">-</p>
                            <p id="profile-bio-summary">Thông tin cá nhân.</p>

                            <div class="meta-row">
                                <span class="author-row">
                                    <span class="icon icon-wrap">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                                    </span>
                                    <span id="profile-provider">-</span>
                                </span>
                                <span class="author-row">
                                    <span class="icon icon-wrap">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4"></path><path d="M8 2v4"></path><path d="M3 10h18"></path></svg>
                                    </span>
                                    <span id="profile-created-at">-</span>
                                </span>
                                <span class="author-row">
                                    <span class="icon icon-wrap">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m22 7-8.5 8.5-5-5L2 17"></path><path d="M16 7h6v6"></path></svg>
                                    </span>
                                    <span id="profile-status">-</span>
                                </span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="mt-24" data-tabs>
                    <div class="tabs">
                        <button class="tab-btn active" type="button" data-tab="overview">Tổng quan</button>
                        <button class="tab-btn" type="button" data-tab="providers">Tài khoản liên kết</button>
                    </div>

                    <div class="tab-panel active" data-panel="overview">
                        <div class="card placeholder-card">
                            Thông tin hồ sơ đã được nối
                        </div>
                    </div>

                    <div class="tab-panel" data-panel="providers">
                        <div class="card">
                            <div class="card-header">
                                <h3>Tài khoản liên kết</h3>
                            </div>
                            <div class="card-content">
                                <div id="profile-connected-providers" class="provider-list"></div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="modal-backdrop" id="edit-profile">
                <div class="modal small">
                    <div class="modal-head">
                        <h3 class="modal-title">Chỉnh sửa trang cá nhân</h3>
                        <button class="icon-btn" type="button" data-close-modal>
                            <span class="icon icon-wrap">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
                            </span>
                        </button>
                    </div>

                    <div class="modal-body">
                        <form id="profile-form" class="vstack gap-3">
                            <div class="form-group">
                                <label for="profile-username">Tên hiển thị</label>
                                <input id="profile-username" class="input" type="text" maxlength="100" required>
                            </div>

                            <div class="form-group">
                                <label for="profile-email">Email</label>
                                <input id="profile-email" class="input" type="email" disabled>
                            </div>

                            <div class="form-group">
                                <label for="profile-bio">Tiểu sử</label>
                                <textarea id="profile-bio" class="textarea" rows="4" maxlength="500" placeholder="Chia sẻ đôi chút về bạn"></textarea>
                            </div>

                            <div class="author-row" style="justify-content:flex-end">
                                <button class="btn btn-outline" type="button" data-close-modal>Hủy</button>
                                <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<div id="toast-container" class="toast-container position-fixed top-0 end-0 p-3"></div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/fptsocial.js" asp-append-version="true"></script>
<script type="module" src="~/js/auth.js" asp-append-version="true"></script>
<script type="module" src="~/js/account-settings.js" asp-append-version="true"></script>
</body>
</html>
