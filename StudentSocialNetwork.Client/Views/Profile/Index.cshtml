@model ProfilePageViewModel
@{
    ViewData["Title"] = "Profile";
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.User is null)
{
    <div class="alert alert-warning">User not found.</div>
}
else
{
    <div class="row g-4">
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5 mb-2">@Model.User.Username</h2>
                    <div class="text-muted mb-3">@Model.User.FullName</div>
                    @if (!string.IsNullOrWhiteSpace(Model.User.AvatarUrl))
                    {
                        <img src="@Model.User.AvatarUrl" class="img-fluid rounded mb-3" alt="Avatar" />
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.User.Bio))
                    {
                        <p>@Model.User.Bio</p>
                    }
                    <div class="small text-muted">Class: @Model.User.ClassName</div>
                    <div class="small text-muted">Major: @Model.User.Major</div>
                    <div class="small text-muted">Interests: @Model.User.Interests</div>
                    <hr />
                    <div class="small">Followers: <strong>@Model.User.FollowersCount</strong></div>
                    <div class="small">Following: <strong>@Model.User.FollowingCount</strong></div>

                    @if (!Model.IsCurrentUser && User.Identity?.IsAuthenticated == true)
                    {
                        <form method="post" action="/profile/@Model.User.Id/follow" class="mt-3">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm @(Model.IsFollowing ? "btn-outline-danger" : "btn-primary")" type="submit">
                                @(Model.IsFollowing ? "Unfollow" : "Follow")
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="h6 mb-3">Posts</h3>
                    @if (Model.Posts.Count == 0)
                    {
                        <div class="text-muted">No posts.</div>
                    }
                    else
                    {
                        foreach (var post in Model.Posts)
                        {
                            <div class="border rounded p-3 mb-3">
                                <div class="d-flex justify-content-between">
                                    <div class="small text-muted">@post.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                    <span class="badge bg-secondary">@post.Status</span>
                                </div>
                                <div class="mt-2">@post.Content</div>
                                <div class="small text-muted mt-2">Likes: @post.LikeCount | Comments: @post.CommentCount</div>
                                <a class="btn btn-sm btn-outline-primary mt-2" href="/post/@post.Id">View detail</a>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}
