@using System.Security.Claims
@{
    var path = Context.Request.Path.Value?.ToLowerInvariant() ?? "/";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var userName = User.FindFirstValue(ClaimTypes.Name) ?? User.Identity?.Name ?? "Người dùng";
    var userInitial = string.IsNullOrWhiteSpace(userName) ? "U" : userName.Trim()[0].ToString().ToUpperInvariant();
    var profileLink = isAuthenticated && !string.IsNullOrWhiteSpace(userId) ? $"/profile/{userId}" : "/account/login";
    var disableShell = (ViewData["DisableAppShell"] as bool?) == true;

    var isHome = path == "/" || path == "/home" || path == "/home/index";
    var isSearch = path.StartsWith("/search");
    var isProfile = path.StartsWith("/profile") && !path.StartsWith("/profile/connections");
    var isConnections = path.StartsWith("/profile/connections");
    var isTrending = path == "/home/trending";
    var isAdminPage = path.StartsWith("/admin/dashboard") || path.StartsWith("/admin/users") || path.StartsWith("/admin/posts");
    var isReportPage = path.StartsWith("/admin/reports");

    var searchKeyword = Context.Request.Query["q"].ToString();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FPTSocial</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/fptsocial.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudentSocialNetwork.Client.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="ssn-body">
@if (disableShell)
{
    <main class="ssn-auth-main">
        @if (TempData["Error"] is string authError && !string.IsNullOrWhiteSpace(authError))
        {
            <div class="alert alert-danger mb-3">@authError</div>
        }
        @if (TempData["Message"] is string authMessage && !string.IsNullOrWhiteSpace(authMessage))
        {
            <div class="alert alert-success mb-3">@authMessage</div>
        }
        @RenderBody()
    </main>
}
else
{
    <div class="ssn-app-shell">
        <header class="ssn-topbar">
            <div class="ssn-topbar-inner">
                <a class="ssn-brand" href="/">
                    <span class="ssn-logo-box">F</span>
                    <span>FPT<span class="ssn-brand-accent">Social</span></span>
                </a>

                <form method="get" action="/search" class="ssn-top-search">
                    <span class="ssn-search-icon">
                        <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="11" cy="11" r="7"></circle>
                            <path d="m20 20-3.5-3.5"></path>
                        </svg>
                    </span>
                    <input type="text" name="q" value="@searchKeyword" placeholder="Tìm kiếm bài viết, người dùng..." />
                </form>

                <div class="ssn-top-actions">
                    @if (isAuthenticated)
                    {
                        <button class="ssn-icon-btn" type="button" title="Thông báo">
                            <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5"></path>
                                <path d="M9 17a3 3 0 0 0 6 0"></path>
                            </svg>
                            <span class="ssn-notify-dot"></span>
                        </button>

                        <div class="dropdown">
                            <button class="ssn-user-chip dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="ssn-avatar">@userInitial</span>
                                <span class="ssn-user-name">@userName</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end ssn-dropdown-menu">
                                <li><a class="dropdown-item" href="@profileLink">Trang cá nhân</a></li>
                                @if (isAdmin)
                                {
                                    <li><a class="dropdown-item" href="/admin/dashboard">Quản trị</a></li>
                                    <li><a class="dropdown-item" href="/admin/reports">Báo cáo thống kê</a></li>
                                }
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form method="post" action="/account/logout" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button class="dropdown-item text-danger" type="submit">Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-primary" href="/account/login">Đăng nhập</a>
                    }
                </div>
            </div>
        </header>

        <div class="ssn-main-layout">
            <aside class="ssn-sidebar">
                <nav class="ssn-side-nav">
                    <a class="ssn-side-link @(isHome ? "active" : string.Empty)" href="/">
                        <span class="ssn-link-icon">
                            <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M3 10.5 12 3l9 7.5"></path>
                                <path d="M5 9.5V21h14V9.5"></path>
                            </svg>
                        </span>
                        <span>Trang chủ</span>
                    </a>
                    <a class="ssn-side-link @(isSearch ? "active" : string.Empty)" href="/search">
                        <span class="ssn-link-icon">
                            <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                                <circle cx="11" cy="11" r="7"></circle>
                                <path d="m20 20-3.5-3.5"></path>
                            </svg>
                        </span>
                        <span>Tìm kiếm</span>
                    </a>
                    <a class="ssn-side-link @(isProfile ? "active" : string.Empty)" href="@profileLink">
                        <span class="ssn-link-icon">
                            <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M20 21a8 8 0 0 0-16 0"></path>
                                <circle cx="12" cy="8" r="4"></circle>
                            </svg>
                        </span>
                        <span>Trang cá nhân</span>
                    </a>
                    <a class="ssn-side-link @(isConnections ? "active" : string.Empty)" href="/profile/connections">
                        <span class="ssn-link-icon">
                            <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                        </span>
                        <span>Kết nối</span>
                    </a>
                    <a class="ssn-side-link @(isTrending ? "active" : string.Empty)" href="/home/trending">
                        <span class="ssn-link-icon">
                            <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="m22 7-8.5 8.5-5-5L2 17"></path>
                                <path d="M16 7h6v6"></path>
                            </svg>
                        </span>
                        <span>Xu hướng</span>
                    </a>
                    @if (isAdmin)
                    {
                        <a class="ssn-side-link @(isAdminPage ? "active" : string.Empty)" href="/admin/dashboard">
                            <span class="ssn-link-icon">
                                <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path>
                                </svg>
                            </span>
                            <span>Quản trị</span>
                        </a>
                        <a class="ssn-side-link @(isReportPage ? "active" : string.Empty)" href="/admin/reports">
                            <span class="ssn-link-icon">
                                <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M3 3v18h18"></path>
                                    <path d="M8 16v-5"></path>
                                    <path d="M12 16v-8"></path>
                                    <path d="M16 16v-3"></path>
                                </svg>
                            </span>
                            <span>Báo cáo</span>
                        </a>
                    }
                </nav>

                <a class="ssn-create-btn" href="@(isAuthenticated ? "/post/create" : "/account/login")">Tạo bài viết</a>
            </aside>

            <main class="ssn-page-main">
                <div class="ssn-page-inner">
                    @if (TempData["Error"] is string error && !string.IsNullOrWhiteSpace(error))
                    {
                        <div class="alert alert-danger mb-3">@error</div>
                    }
                    @if (TempData["Message"] is string message && !string.IsNullOrWhiteSpace(message))
                    {
                        <div class="alert alert-success mb-3">@message</div>
                    }
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>
}

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
