@{
    Layout = null;
}

<!doctype html><html lang="vi"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Register</title><link rel="stylesheet" href="/css/fptsocial.css"></head><body class="auth-body">
<div class="auth-wrap">
  <div class="auth-logo"><div class="logo-box">F</div><h1>FPT<span class="brand-accent">Social</span></h1><p>Tham gia cộng đồng sinh viên FPT</p></div>
  <section class="card">
    <div class="card-header"><h2>Tạo tài khoản mới</h2><p>Điền thông tin để đăng ký tài khoản FPTSocial</p></div>
    <div class="card-content">
      <form>
        <div class="form-group"><label>Tên người dùng</label><input class="input" type="text" placeholder="nguyenvana"></div>
        <div class="form-group"><label>Email FPT</label><input class="input" type="email" placeholder="nguyenvana@@fpt.edu.vn"></div>
        <div class="form-group"><label>Mật khẩu</label><input class="input" type="password" placeholder="Tối thiểu 8 ký tự"></div>
        <div class="form-group"><label>Xác nhận mật khẩu</label><input class="input" type="password" placeholder="Nhập lại mật khẩu"></div>
        <a class="btn btn-primary full" href="/auth/login">Đăng ký</a>
      </form>
      <div class="auth-foot"><span>Đã có tài khoản? </span><a href="/auth/login"><strong>Đăng nhập</strong></a></div>
    </div>
  </section>
  <p class="legal">Bằng cách đăng ký, bạn đồng ý với <a href="#">Điều khoản sử dụng</a> và <a href="#">Chính sách bảo mật</a></p>
</div><script src="/js/fptsocial.js"></script></body></html>