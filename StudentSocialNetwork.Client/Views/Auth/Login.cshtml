@{
    ViewData["Title"] = "Login";
}

<div class="container py-5 auth-page">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <h1 class="h4 mb-3">Sign in to Chat</h1>
                    <p class="text-muted mb-4">Continue with your Google account to access Student Social Network.</p>

                    @if (ViewData["Error"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="alert alert-danger text-start" role="alert">@errorMessage</div>
                    }

                    <a class="btn btn-danger btn-lg px-4" href="/auth/login/google">Continue with Google</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module">
        import { getAccessToken } from '/js/auth.js';

        if (getAccessToken()) {
            window.location.replace('/conversations');
        }
    </script>
}
