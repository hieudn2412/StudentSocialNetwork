@model PostEditViewModel
@{
    ViewData["Title"] = "Edit Post";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">Edit Post</h2>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form method="post" asp-action="Edit" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <textarea class="form-control" asp-for="Content" rows="5" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Image URL</label>
                        <input class="form-control" asp-for="ImageUrl" />
                    </div>
                    <button class="btn btn-primary" type="submit">Save</button>
                    <a class="btn btn-outline-secondary" href="/post/@Model.Id">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
