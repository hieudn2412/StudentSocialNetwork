@model PostEditViewModel
@{
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="ssn-page-header">
    <h1>Chỉnh sửa bài viết</h1>
    <p>Cập nhật nội dung bài viết của bạn</p>
</div>

<section class="ssn-surface ssn-card-body">
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post" asp-action="Edit" asp-route-id="@Model.Id" class="d-grid gap-3">
        @Html.AntiForgeryToken()

        <div>
            <label class="form-label">Nội dung</label>
            <textarea class="form-control" asp-for="Content" rows="7" required></textarea>
        </div>

        <div>
            <label class="form-label">Image URL</label>
            <input class="form-control" asp-for="ImageUrl" />
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
            <a class="btn btn-outline-secondary" href="/post/@Model.Id">Hủy</a>
        </div>
    </form>
</section>
