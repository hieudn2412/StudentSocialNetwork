@model PostCreateViewModel
@{
    ViewData["Title"] = "Tạo bài viết";
}

<div class="ssn-page-header">
    <h1>Tạo bài viết</h1>
    <p>Chia sẻ nội dung mới lên bảng tin</p>
</div>

<section class="ssn-surface ssn-card-body">
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post" enctype="multipart/form-data" asp-action="Create" class="d-grid gap-3">
        @Html.AntiForgeryToken()

        <div>
            <label class="form-label">Nội dung</label>
            <textarea class="form-control" asp-for="Content" rows="7" placeholder="Bạn đang nghĩ gì?" required></textarea>
        </div>

        <div>
            <label class="form-label">Hình ảnh</label>
            <input class="form-control" asp-for="Image" type="file" accept="image/*" />
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" type="submit">Đăng bài</button>
            <a class="btn btn-outline-secondary" href="/">Hủy</a>
        </div>
    </form>
</section>
