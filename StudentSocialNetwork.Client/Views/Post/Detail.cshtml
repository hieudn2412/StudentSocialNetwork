@using System.Security.Claims
@model PostDetailViewModel
@{
    ViewData["Title"] = "Post Detail";
    var currentUserIdText = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner = Model.Post is not null && currentUserIdText == Model.Post.AuthorId.ToString();
    var isAdmin = User.IsInRole("Admin");
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.Post is null)
{
    <div class="alert alert-warning">Post not found.</div>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between">
                <div>
                    <a class="fw-semibold text-decoration-none" href="/profile/@Model.Post.AuthorId">@Model.Post.AuthorName</a>
                    <div class="small text-muted">@Model.Post.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <span class="badge bg-secondary">@Model.Post.Status</span>
            </div>

            <p class="mt-3">@Model.Post.Content</p>
            @if (!string.IsNullOrWhiteSpace(Model.Post.ImageUrl))
            {
                <img src="@Model.Post.ImageUrl" class="img-fluid rounded mb-2" alt="Post image" />
            }
            @if (!string.IsNullOrWhiteSpace(Model.Post.Hashtags))
            {
                <div class="small text-primary">@Model.Post.Hashtags</div>
            }

            <div class="d-flex gap-2 mt-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form method="post" action="/posts/@Model.Post.Id/like">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                        <button class="btn btn-sm @(Model.Post.IsLikedByMe ? "btn-danger" : "btn-outline-danger")" type="submit">
                            @(Model.Post.IsLikedByMe ? "Unlike" : "Like") (@Model.Post.LikeCount)
                        </button>
                    </form>
                }
                else
                {
                    <span class="btn btn-sm btn-outline-secondary disabled">Like (@Model.Post.LikeCount)</span>
                }
                <span class="btn btn-sm btn-outline-secondary disabled">Comments (@Model.Post.CommentCount)</span>
            </div>

            @if (User.Identity?.IsAuthenticated == true && (isOwner || isAdmin))
            {
                <div class="mt-3">
                    <a class="btn btn-sm btn-outline-primary" href="/post/edit/@Model.Post.Id">Edit</a>
                    <form class="d-inline" method="post" action="/post/delete/@Model.Post.Id">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </div>
            }
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h3 class="h6 mb-3">Comments</h3>
            @if (Model.Comments.Count == 0)
            {
                <div class="text-muted">No comments yet.</div>
            }
            else
            {
                foreach (var comment in Model.Comments)
                {
                    <div class="border rounded p-2 mb-2">
                        <div class="small text-muted">
                            <strong>@comment.AuthorName</strong> • @comment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </div>
                        <div>@comment.Content</div>
                    </div>
                }
            }
        </div>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="h6 mb-3">Add Comment</h3>
                <form method="post" asp-action="AddComment" asp-route-id="@Model.Post.Id">
                    @Html.AntiForgeryToken()
                    <textarea class="form-control mb-3" asp-for="NewComment" rows="3" required></textarea>
                    <button class="btn btn-primary" type="submit">Comment</button>
                </form>
            </div>
        </div>
    }
}
