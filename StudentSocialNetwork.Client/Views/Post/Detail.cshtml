@using System.Security.Claims
@model PostDetailViewModel
@{
    ViewData["Title"] = "Chi tiết bài viết";
    var currentUserIdText = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner = Model.Post is not null && currentUserIdText == Model.Post.AuthorId.ToString();
    var isAdmin = User.IsInRole("Admin");
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.Post is null)
{
    <div class="ssn-surface ssn-empty">Không tìm thấy bài viết.</div>
}
else
{
    var avatar = string.IsNullOrWhiteSpace(Model.Post.AuthorName) ? "U" : Model.Post.AuthorName.Trim()[0].ToString().ToUpperInvariant();

    <section class="ssn-surface ssn-post-card mb-3">
        <header class="ssn-post-head">
            <div class="ssn-author-block">
                <span class="ssn-avatar-lg">@avatar</span>
                <div>
                    <a class="ssn-author-name" href="/profile/@Model.Post.AuthorId">@Model.Post.AuthorName</a>
                    <div class="ssn-author-meta">@Model.Post.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            </div>
        </header>

        <div class="ssn-post-content">@Model.Post.Content</div>

        @if (!string.IsNullOrWhiteSpace(Model.Post.ImageUrl))
        {
            <img class="ssn-post-image" src="@Model.Post.ImageUrl" alt="Post image" />
        }

        @if (!string.IsNullOrWhiteSpace(Model.Post.Hashtags))
        {
            <div class="ssn-muted mb-2">@Model.Post.Hashtags</div>
        }

        <div class="ssn-post-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form method="post" action="/posts/@Model.Post.Id/like">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button class="btn btn-sm @(Model.Post.IsLikedByMe ? "btn-danger" : "btn-outline-danger")" type="submit">
                        ♥ @Model.Post.LikeCount
                    </button>
                </form>
            }
            else
            {
                <span class="btn btn-sm btn-outline-secondary disabled">♥ @Model.Post.LikeCount</span>
            }
            <span class="btn btn-sm btn-outline-secondary disabled">💬 @Model.Post.CommentCount</span>
        </div>

        @if (User.Identity?.IsAuthenticated == true && (isOwner || isAdmin))
        {
            <div class="d-flex gap-2 mt-3">
                <a class="btn btn-sm btn-outline-primary" href="/post/edit/@Model.Post.Id">Sửa</a>
                <form method="post" action="/post/delete/@Model.Post.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                </form>
            </div>
        }
    </section>

    <section class="ssn-surface ssn-card-body mb-3">
        <h2 class="ssn-section-title">Bình luận</h2>

        @if (Model.Comments.Count == 0)
        {
            <div class="ssn-empty">Chưa có bình luận nào.</div>
        }
        else
        {
            <div class="ssn-comments">
                @foreach (var comment in Model.Comments)
                {
                    <article class="ssn-comment-item">
                        <div class="ssn-comment-meta"><strong>@comment.AuthorName</strong> • @comment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                        <div>@comment.Content</div>
                    </article>
                }
            </div>
        }
    </section>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <section class="ssn-surface ssn-card-body">
            <h2 class="ssn-section-title">Thêm bình luận</h2>
            <form method="post" asp-action="AddComment" asp-route-id="@Model.Post.Id" class="mt-3">
                @Html.AntiForgeryToken()
                <textarea class="form-control mb-3" asp-for="NewComment" rows="4" placeholder="Nhập nội dung bình luận..." required></textarea>
                <button class="btn btn-primary" type="submit">Gửi bình luận</button>
            </form>
        </section>
    }
}
