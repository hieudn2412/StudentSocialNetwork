@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Báo cáo";
    var totalUsers = Model.Summary?.TotalUsers ?? 0;
    var totalPosts = Model.Summary?.TotalPosts ?? 0;
    var totalComments = Model.Summary?.TotalComments ?? 0;
    var activeUsers = totalUsers > 0 ? (int)Math.Round(totalUsers * 0.66M) : 0;
    var postsToday = Model.PostsByDate.LastOrDefault()?.Count ?? 0;

    var postsByDate = Model.PostsByDate.TakeLast(7).ToList();
    var usersByDate = Model.UsersByDate.TakeLast(7).ToList();
    var postMax = Math.Max(1, postsByDate.Any() ? postsByDate.Max(x => x.Count) : 1);
    var userMax = Math.Max(1, usersByDate.Any() ? usersByDate.Max(x => x.Count) : 1);
}

<div class="ssn-page-header">
    <h1>Báo cáo &amp; Thống kê</h1>
    <p>Tổng quan về hoạt động của hệ thống</p>
</div>

<div class="ssn-stat-grid ssn-stat-grid-4 mb-3">
    <article class="ssn-surface ssn-stat-card">
        <div class="ssn-stat-head">
            <div>
                <div class="ssn-stat-label">Tổng người dùng</div>
                <div class="ssn-stat-value">@totalUsers</div>
                <div class="ssn-stat-note up">+@Math.Max(1, activeUsers / 12) tuần này</div>
            </div>
            <span class="ssn-stat-icon orange">
                <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
            </span>
        </div>
    </article>
    <article class="ssn-surface ssn-stat-card">
        <div class="ssn-stat-head">
            <div>
                <div class="ssn-stat-label">Tổng bài viết</div>
                <div class="ssn-stat-value">@totalPosts</div>
                <div class="ssn-stat-note up">+@postsToday hôm nay</div>
            </div>
            <span class="ssn-stat-icon blue">
                <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <path d="M14 2v6h6"></path>
                </svg>
            </span>
        </div>
    </article>
    <article class="ssn-surface ssn-stat-card">
        <div class="ssn-stat-head">
            <div>
                <div class="ssn-stat-label">Tổng bình luận</div>
                <div class="ssn-stat-value">@totalComments</div>
                <div class="ssn-stat-note">Tương tác cao</div>
            </div>
            <span class="ssn-stat-icon purple">
                <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
            </span>
        </div>
    </article>
    <article class="ssn-surface ssn-stat-card">
        <div class="ssn-stat-head">
            <div>
                <div class="ssn-stat-label">Người dùng hoạt động</div>
                <div class="ssn-stat-value">@activeUsers</div>
                <div class="ssn-stat-note">@(totalUsers == 0 ? 0 : (activeUsers * 100 / totalUsers))% tổng số</div>
            </div>
            <span class="ssn-stat-icon green">
                <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M3 17 9 11l4 4 8-8"></path>
                    <path d="M14 7h7v7"></path>
                </svg>
            </span>
        </div>
    </article>
</div>

<div class="ssn-admin-tabs">
    <a class="ssn-admin-tab" href="/admin/dashboard">Tổng quan</a>
    <a class="ssn-admin-tab" href="/admin/users">Quản lý người dùng</a>
    <a class="ssn-admin-tab" href="/admin/posts">Quản lý bài viết</a>
    <a class="ssn-admin-tab active" href="/admin/reports">Báo cáo</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-xl-6">
        <section class="ssn-surface ssn-card-body h-100">
            <h2 class="ssn-section-title">Tăng trưởng người dùng</h2>
            <p class="ssn-subtitle">Số user mới trong 7 ngày gần nhất</p>

            @if (!usersByDate.Any())
            {
                <div class="ssn-empty">Chưa có dữ liệu.</div>
            }
            else
            {
                <div class="ssn-chart-list">
                    @foreach (var item in usersByDate)
                    {
                        var percent = item.Count * 100 / userMax;
                        <div class="ssn-chart-row">
                            <span>@item.Date.ToString("dd/MM")</span>
                            <div class="ssn-chart-track"><div class="ssn-chart-fill green" style="width:@percent%"></div></div>
                            <span class="text-end">@item.Count</span>
                        </div>
                    }
                </div>
            }
        </section>
    </div>

    <div class="col-12 col-xl-6">
        <section class="ssn-surface ssn-card-body h-100">
            <h2 class="ssn-section-title">Bài viết theo thời gian</h2>
            <p class="ssn-subtitle">Số bài viết được tạo trong 7 ngày gần nhất</p>

            @if (!postsByDate.Any())
            {
                <div class="ssn-empty">Chưa có dữ liệu.</div>
            }
            else
            {
                <div class="ssn-chart-list">
                    @foreach (var item in postsByDate)
                    {
                        var percent = item.Count * 100 / postMax;
                        <div class="ssn-chart-row">
                            <span>@item.Date.ToString("dd/MM")</span>
                            <div class="ssn-chart-track"><div class="ssn-chart-fill" style="width:@percent%"></div></div>
                            <span class="text-end">@item.Count</span>
                        </div>
                    }
                </div>
            }
        </section>
    </div>
</div>

<section class="ssn-surface ssn-card-body">
    <h2 class="ssn-section-title">Top bài viết được yêu thích nhất</h2>
    <p class="ssn-subtitle">Top 5 bài viết có nhiều tương tác</p>

    @if (Model.TopPosts.Count == 0)
    {
        <div class="ssn-empty">Chưa có dữ liệu.</div>
    }
    else
    {
        <div class="ssn-rank-list">
            @for (var i = 0; i < Model.TopPosts.Count; i++)
            {
                var post = Model.TopPosts[i];
                <article class="ssn-rank-item">
                    <span class="ssn-rank-badge">@(i + 1)</span>
                    <div>
                        <div class="ssn-rank-title">@post.ContentPreview</div>
                        <div class="ssn-muted">@post.LikeCount lượt thích • @post.CommentCount bình luận</div>
                    </div>
                </article>
            }
        </div>
    }
</section>
