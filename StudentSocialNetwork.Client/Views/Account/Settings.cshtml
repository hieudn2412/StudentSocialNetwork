@model AccountSettingsViewModel
@{
    ViewData["Title"] = "Account Settings";
}

<div class="row">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Profile Settings</h2>

                @if (!string.IsNullOrWhiteSpace(Model.Message))
                {
                    <div class="alert alert-success">@Model.Message</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form method="post" asp-action="Settings">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input class="form-control" asp-for="Username" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" asp-for="Email" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input class="form-control" asp-for="FullName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Avatar URL</label>
                        <input class="form-control" asp-for="AvatarUrl" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bio</label>
                        <textarea class="form-control" asp-for="Bio" rows="3"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Class</label>
                            <input class="form-control" asp-for="ClassName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Major</label>
                            <input class="form-control" asp-for="Major" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Interests</label>
                        <input class="form-control" asp-for="Interests" />
                    </div>

                    <hr />
                    <h3 class="h6">Change Password</h3>
                    <div class="mb-3">
                        <label class="form-label">Current Password</label>
                        <input class="form-control" asp-for="CurrentPassword" type="password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <input class="form-control" asp-for="NewPassword" type="password" />
                    </div>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </form>
            </div>
        </div>
    </div>
</div>
