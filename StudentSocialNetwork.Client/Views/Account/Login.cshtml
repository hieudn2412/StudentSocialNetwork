@model AccountLoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    ViewData["DisableAppShell"] = true;
}

<section class="ssn-auth-card">
    <div class="ssn-auth-brand">
        <div class="ssn-auth-logo">F</div>
        <h1 class="ssn-auth-title">FPT<span class="ssn-brand-accent">Social</span></h1>
        <p class="ssn-auth-subtitle">Hệ thống nội bộ - chỉ hỗ trợ đăng nhập bằng Gmail của trường</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <a class="btn btn-danger w-100 py-2" href="@Url.Action("LoginGoogle", "Auth", new { returnUrl = Model.ReturnUrl })">
        Tiếp tục với Google
    </a>

    <div class="ssn-auth-footer">
        Chưa có tài khoản? <a href="/account/register">Đăng ký</a>
    </div>
</section>
