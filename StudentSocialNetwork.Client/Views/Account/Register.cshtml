@model AccountRegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    ViewData["DisableAppShell"] = true;
}

<section class="ssn-auth-card">
    <div class="ssn-auth-brand">
        <div class="ssn-auth-logo">F</div>
        <h1 class="ssn-auth-title">Tạo tài khoản mới</h1>
        <p class="ssn-auth-subtitle">Tham gia cộng đồng FPTSocial</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post" asp-action="Register" class="d-grid gap-3">
        @Html.AntiForgeryToken()

        <div>
            <label class="ssn-form-label">Username</label>
            <input class="form-control ssn-form-control" asp-for="Username" required />
        </div>

        <div>
            <label class="ssn-form-label">Họ và tên</label>
            <input class="form-control ssn-form-control" asp-for="FullName" />
        </div>

        <div>
            <label class="ssn-form-label">Email</label>
            <input class="form-control ssn-form-control" asp-for="Email" type="email" required />
        </div>

        <div>
            <label class="ssn-form-label">Mật khẩu</label>
            <input class="form-control ssn-form-control" asp-for="Password" type="password" required />
        </div>

        <button type="submit" class="btn btn-primary w-100">Tạo tài khoản</button>
    </form>

    <div class="ssn-auth-footer">
        Đã có tài khoản? <a href="/account/login">Đăng nhập</a>
    </div>
</section>
