@model AccountRegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Register</h2>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form method="post" asp-action="Register">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input class="form-control" asp-for="Username" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input class="form-control" asp-for="FullName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" asp-for="Email" type="email" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input class="form-control" asp-for="Password" type="password" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Create account</button>
                </form>

                <p class="small text-muted mt-3 mb-0">
                    Đã có tài khoản? <a href="/account/login">Đăng nhập</a>
                </p>
            </div>
        </div>
    </div>
</div>
