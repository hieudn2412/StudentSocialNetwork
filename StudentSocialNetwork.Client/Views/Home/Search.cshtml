@model SearchViewModel
@{
    ViewData["Title"] = "Tìm kiếm";
}

<div class="ssn-page-header">
    <h1>Tìm kiếm</h1>
    <p>Tìm người dùng và bài viết trong hệ thống</p>
</div>

<section class="ssn-surface ssn-card-body mb-3">
    <form method="get" action="/search" class="d-flex gap-2">
        <input class="form-control" type="text" name="q" placeholder="Tìm kiếm bài viết, người dùng..." value="@Model.Query" />
        <button class="btn btn-primary" type="submit">Tìm</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(Model.Query))
{
    <div class="ssn-search-grid">
        <section class="ssn-surface ssn-card-body">
            <h2 class="ssn-section-title">Người dùng</h2>
            <p class="ssn-subtitle">Kết quả phù hợp theo tên và username</p>

            @if (Model.Users.Count == 0)
            {
                <div class="ssn-empty">Không tìm thấy người dùng nào.</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var user in Model.Users)
                    {
                        <a class="list-group-item list-group-item-action" href="/profile/@user.Id">
                            <div class="fw-semibold">@user.Username</div>
                            <div class="small text-muted">@user.FullName</div>
                        </a>
                    }
                </div>
            }
        </section>

        <section class="ssn-surface ssn-card-body">
            <h2 class="ssn-section-title">Bài viết</h2>
            <p class="ssn-subtitle">Nội dung liên quan đến từ khóa</p>

            @if (Model.Posts.Count == 0)
            {
                <div class="ssn-empty">Không tìm thấy bài viết nào.</div>
            }
            else
            {
                foreach (var post in Model.Posts)
                {
                    <article class="ssn-surface ssn-card-body mb-2">
                        <a class="ssn-author-name" href="/profile/@post.AuthorId">@post.AuthorName</a>
                        <div class="ssn-post-content">@post.Content</div>
                        <a class="btn btn-sm btn-outline-primary" href="/post/@post.Id">Mở chi tiết</a>
                    </article>
                }
            }
        </section>
    </div>
}
else
{
    <div class="ssn-surface ssn-empty">Nhập từ khóa để bắt đầu tìm kiếm.</div>
}
