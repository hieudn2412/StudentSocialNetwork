@model SearchViewModel
@{
    ViewData["Title"] = "Search";
}

<div class="row">
    <div class="col-12">
        <form method="get" action="/search" class="mb-4">
            <div class="input-group">
                <input class="form-control" type="text" name="q" placeholder="Search users and posts..." value="@Model.Query" />
                <button class="btn btn-primary" type="submit">Search</button>
            </div>
        </form>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Query))
{
    <div class="row g-4">
        <div class="col-12 col-lg-5">
            <h2 class="h5">Users</h2>
            @if (Model.Users.Count == 0)
            {
                <div class="text-muted">No users found.</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var user in Model.Users)
                    {
                        <a class="list-group-item list-group-item-action" href="/profile/@user.Id">
                            <div class="fw-semibold">@user.Username</div>
                            <div class="small text-muted">@user.FullName</div>
                        </a>
                    }
                </div>
            }
        </div>

        <div class="col-12 col-lg-7">
            <h2 class="h5">Posts</h2>
            @if (Model.Posts.Count == 0)
            {
                <div class="text-muted">No posts found.</div>
            }
            else
            {
                @foreach (var post in Model.Posts)
                {
                    <div class="card mb-3">
                        <div class="card-body">
                            <a class="fw-semibold text-decoration-none" href="/profile/@post.AuthorId">@post.AuthorName</a>
                            <p class="mb-2 mt-2">@post.Content</p>
                            <a class="btn btn-sm btn-outline-primary" href="/post/@post.Id">Open</a>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}
