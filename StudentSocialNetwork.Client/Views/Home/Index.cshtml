@model FeedViewModel
@{
    ViewData["Title"] = "Feed";
}

<div class="row g-4">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <form method="get" action="/">
                    <div class="row g-2">
                        <div class="col-md-3">
                            <select class="form-select" name="tab">
                                <option value="all" selected="@(Model.Tab == "all")">All</option>
                                <option value="following" selected="@(Model.Tab == "following")">Following</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <input class="form-control" type="text" name="search" placeholder="Search content/author" value="@Model.Search" />
                        </div>
                        <div class="col-md-3">
                            <input class="form-control" type="text" name="hashtag" placeholder="Hashtag" value="@Model.Hashtag" />
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-primary w-100" type="submit">Filter</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.Posts.Count == 0)
        {
            <div class="alert alert-light border">Chưa có bài viết phù hợp.</div>
        }
        else
        {
            foreach (var post in Model.Posts)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <a class="fw-semibold text-decoration-none" href="/profile/@post.AuthorId">@post.AuthorName</a>
                                <div class="small text-muted">@post.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                            <div class="small">
                                <span class="badge bg-secondary">@post.Status</span>
                            </div>
                        </div>

                        <p class="mt-3 mb-2">@post.Content</p>
                        @if (!string.IsNullOrWhiteSpace(post.ImageUrl))
                        {
                            <img src="@post.ImageUrl" class="img-fluid rounded mb-2" alt="Post image" />
                        }
                        @if (!string.IsNullOrWhiteSpace(post.Hashtags))
                        {
                            <div class="small text-primary">@post.Hashtags</div>
                        }

                        <div class="d-flex gap-2 mt-3">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form method="post" action="/posts/@post.Id/like">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button class="btn btn-sm @(post.IsLikedByMe ? "btn-danger" : "btn-outline-danger")" type="submit">
                                        @(post.IsLikedByMe ? "Unlike" : "Like") (@post.LikeCount)
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="btn btn-sm btn-outline-secondary disabled">Like (@post.LikeCount)</span>
                            }
                            <a class="btn btn-sm btn-outline-secondary" href="/post/@post.Id">Comments (@post.CommentCount)</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="col-12 col-lg-4">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="h6 mb-3">Suggested Users</h3>
                    @if (Model.Suggestions.Count == 0)
                    {
                        <div class="text-muted small">No suggestions right now.</div>
                    }
                    else
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var user in Model.Suggestions)
                            {
                                <li class="mb-2">
                                    <a class="text-decoration-none" href="/profile/@user.Id">
                                        <strong>@user.Username</strong>
                                        @if (!string.IsNullOrWhiteSpace(user.FullName))
                                        {
                                            <span class="text-muted">(@user.FullName)</span>
                                        }
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        }
    </div>
</div>
