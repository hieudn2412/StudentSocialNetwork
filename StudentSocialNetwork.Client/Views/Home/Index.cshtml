            </div>
        </main>

        <aside class="right-sidebar">
            <section class="card side-card">
                <div class="card-header">
                    <h3>Thong tin tai khoan</h3>
                </div>
                <div class="card-content gap-12">
                    <div class="profile-chip">
                        <img id="home-side-user-avatar" class="avatar avatar-md" src="" alt="Side avatar">
                        <span id="home-side-user-name">Account</span>
                    </div>
                    <p id="home-side-user-email" class="muted small">Chua co email</p>
                    <a class="btn btn-outline btn-sm" href="/profile">Xem trang ca nhan</a>
                    <a class="btn btn-soft btn-sm" href="/settings">Mo cai dat tai khoan</a>
                </div>
            </section>

            <section class="card side-card">
                <div class="card-header">
                    <h3>Xu huong</h3>
                </div>
                <div class="card-content gap-12">
                    <div class="trend-item"><div><p class="trend-tag">#ReactJS</p><p class="muted small">234 bai viet</p></div></div>
                    <div class="trend-item"><div><p class="trend-tag">#FPTLife</p><p class="muted small">189 bai viet</p></div></div>
                    <div class="trend-item"><div><p class="trend-tag">#MachineLearning</p><p class="muted small">156 bai viet</p></div></div>
                </div>
            </section>
        </aside>
    </div>
</div>

<div id="toast-container" class="toast-container position-fixed top-0 end-0 p-3"></div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/fptsocial.js" asp-append-version="true"></script>
<script type="module" src="~/js/auth.js" asp-append-version="true"></script>
<script>
    (function () {
        function getAuthState() {
            try {
                const raw = localStorage.getItem('ssn.auth');
                return raw ? JSON.parse(raw) : null;
            } catch {
                return null;
            }
        }

        function getInitials(value) {
            const text = String(value || 'U')
                .trim()
                .split(/\s+/)
                .filter(Boolean)
                .slice(0, 2)
                .map((part) => part[0] ? part[0].toUpperCase() : '')
                .join('');

            return text || 'U';
        }

        function resolveAvatarUrl(auth) {
            if (auth && auth.avatarUrl) {
                return auth.avatarUrl;
            }

            const initials = getInitials(auth?.username || auth?.email || 'U');
            const svg = "<svg xmlns='http://www.w3.org/2000/svg' width='96' height='96'><rect width='100%' height='100%' fill='%23e2e8f0'/><text x='50%' y='53%' dominant-baseline='middle' text-anchor='middle' font-family='Segoe UI, Arial' font-size='34' fill='%23334155'>" + initials + "</text></svg>";
            return 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent(svg);
        }

        function setText(id, value, fallback) {
            const element = document.getElementById(id);
            if (!element) {
                return;
            }

            element.textContent = value || fallback;
        }

        function setImage(id, src) {
            const element = document.getElementById(id);
            if (!element) {
                return;
            }

            element.src = src;
        }

        function syncHomeAuthState() {
            const auth = getAuthState();
            const displayName = auth?.username || auth?.email || 'Account';
            const avatarUrl = resolveAvatarUrl(auth);

            setText('home-current-user-name', displayName, 'Account');
            setText('home-side-user-name', displayName, 'Account');
            setText('home-side-user-email', auth?.email, 'Chua co email');
            setImage('home-current-user-avatar', avatarUrl);
            setImage('home-side-user-avatar', avatarUrl);
        }

        document.addEventListener('DOMContentLoaded', syncHomeAuthState);
    })();
</script>
</body>
</html>
