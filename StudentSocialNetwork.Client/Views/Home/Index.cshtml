@model FeedViewModel
@{
    ViewData["Title"] = "Trang chủ";
    var meName = User.Identity?.Name ?? "U";
    var meInitial = string.IsNullOrWhiteSpace(meName) ? "U" : meName.Trim()[0].ToString().ToUpperInvariant();
}

<div class="ssn-feed-grid">
    <div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <section class="ssn-surface ssn-card-body mb-3">
                <div class="d-flex gap-3 mb-3">
                    <span class="ssn-avatar-lg">@meInitial</span>
                    <div class="flex-grow-1">
                        <textarea class="form-control ssn-compose-input" placeholder="Bạn đang nghĩ gì?" disabled></textarea>
                    </div>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <div class="ssn-inline-meta">
                        <svg class="ssn-icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                            <circle cx="8.5" cy="9" r="1.5"></circle>
                            <path d="m21 15-4-4-5 5-2-2-5 5"></path>
                        </svg>
                        <span>Hình ảnh</span>
                    </div>
                    <a class="btn btn-primary" href="/post/create">Đăng bài</a>
                </div>
            </section>
        }

        <section class="ssn-surface ssn-card-body mb-3">
            <form method="get" action="/" class="ssn-filter-row">
                <select class="form-select" name="tab">
                    <option value="all" selected="@(Model.Tab == "all")">All</option>
                    <option value="following" selected="@(Model.Tab == "following")">Following</option>
                </select>
                <input class="form-control" type="text" name="search" placeholder="Tìm nội dung hoặc tác giả" value="@Model.Search" />
                <input class="form-control" type="text" name="hashtag" placeholder="#hashtag" value="@Model.Hashtag" />
                <button class="btn btn-primary" type="submit">Lọc</button>
            </form>
        </section>

        <div class="ssn-feed-stack">
            @if (Model.Posts.Count == 0)
            {
                <div class="ssn-surface ssn-empty">Chưa có bài viết phù hợp.</div>
            }
            else
            {
                foreach (var post in Model.Posts)
                {
                    var avatar = string.IsNullOrWhiteSpace(post.AuthorName) ? "U" : post.AuthorName.Trim()[0].ToString().ToUpperInvariant();

                    <article class="ssn-surface ssn-post-card">
                        <header class="ssn-post-head">
                            <div class="ssn-author-block">
                                <span class="ssn-avatar-lg">@avatar</span>
                                <div>
                                    <a class="ssn-author-name" href="/profile/@post.AuthorId">@post.AuthorName</a>
                                    <div class="ssn-author-meta">@post.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                            </div>
                        </header>

                        <div class="ssn-post-content">@post.Content</div>

                        @if (!string.IsNullOrWhiteSpace(post.ImageUrl))
                        {
                            <img class="ssn-post-image" src="@post.ImageUrl" alt="Post image" />
                        }

                        @if (!string.IsNullOrWhiteSpace(post.Hashtags))
                        {
                            <div class="ssn-muted mb-2">@post.Hashtags</div>
                        }

                        <div class="ssn-post-actions">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form method="post" action="/posts/@post.Id/like">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button class="btn btn-sm @(post.IsLikedByMe ? "btn-danger" : "btn-outline-danger")" type="submit">♥ @post.LikeCount</button>
                                </form>
                            }
                            else
                            {
                                <span class="btn btn-sm btn-outline-secondary disabled">♥ @post.LikeCount</span>
                            }
                            <a class="btn btn-sm btn-outline-secondary" href="/post/@post.Id">💬 @post.CommentCount</a>
                        </div>
                    </article>
                }
            }
        </div>
    </div>

    <aside>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <section class="ssn-surface ssn-card-body">
                <h2 class="ssn-section-title">Gợi ý kết nối</h2>
                <p class="ssn-subtitle">Những người bạn có thể quan tâm</p>

                @if (Model.Suggestions.Count == 0)
                {
                    <div class="ssn-empty">Chưa có gợi ý lúc này.</div>
                }
                else
                {
                    <ul class="ssn-user-list">
                        @foreach (var user in Model.Suggestions)
                        {
                            <li>
                                <a href="/profile/@user.Id">
                                    <strong>@user.Username</strong>
                                    @if (!string.IsNullOrWhiteSpace(user.FullName))
                                    {
                                        <span class="ssn-muted"> (@user.FullName)</span>
                                    }
                                </a>
                            </li>
                        }
                    </ul>
                }
            </section>
        }
    </aside>
</div>
