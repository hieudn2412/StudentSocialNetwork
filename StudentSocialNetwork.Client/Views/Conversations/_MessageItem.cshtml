<div class="message-item" data-message-id="0">
    <div class="message-head d-flex justify-content-between align-items-center">
        <strong class="message-sender">Sender</strong>
        <small class="message-time text-muted"></small>
    </div>
    <div class="message-reply small text-muted d-none"></div>
    <div class="message-content mt-1"></div>
    <div class="message-attachments mt-2 d-flex flex-wrap gap-2"></div>
    <div class="message-reactions mt-2 d-flex flex-wrap gap-2"></div>
    <div class="message-actions mt-2 d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="reply">Reply</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="react">Toggle reaction</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="pin">Pin/Unpin</button>
    </div>
</div>

