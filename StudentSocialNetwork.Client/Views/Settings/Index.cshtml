@{
    Layout = null;
}

<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Settings</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/fptsocial.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/account-settings.css" asp-append-version="true" />
</head>
<body>
<div id="account-page" class="app-shell" data-page="settings">
    <nav class="topbar">
        <div class="topbar-inner">
            <a href="/home" class="logo">
                <div class="logo-box">F</div>
                <span>FPT<span class="brand-accent">Social</span></span>
            </a>

            <div class="top-actions ms-auto">
                <a id="nav-login-link" class="btn btn-outline-primary btn-sm" href="/auth/login">Login</a>

                <div id="nav-auth-menu" class="dropdown d-none">
                    <button class="btn btn-light btn-sm dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <img id="nav-profile-avatar" class="rounded-circle" src="" alt="Avatar" width="26" height="26" />
                        <span id="nav-profile-name" class="fw-semibold">Account</span>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        <li><a class="dropdown-item" href="/profile">Profile</a></li>
                        <li><a class="dropdown-item" href="/settings">Settings</a></li>
                        <li><a class="dropdown-item" href="/conversations">Conversations</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><button id="nav-logout-button" class="dropdown-item text-danger" type="button">Logout</button></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="main-layout">
        <aside class="left-sidebar">
            <nav>
                <a href="/home" class="nav-link">
                    <span class="icon icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 10.5 12 3l9 7.5"></path><path d="M5 9.5V21h14V9.5"></path></svg>
                    </span>
                    <span>Trang chu</span>
                </a>
                <a href="/conversations" class="nav-link">
                    <span class="icon icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    </span>
                    <span>Tro chuyen</span>
                </a>
                <a href="/profile" class="nav-link">
                    <span class="icon icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21a8 8 0 0 0-16 0"></path><circle cx="12" cy="8" r="4"></circle></svg>
                    </span>
                    <span>Trang ca nhan</span>
                </a>
                <a href="/settings" class="nav-link active">
                    <span class="icon icon-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M12 2v3"></path><path d="M12 19v3"></path><path d="m4.93 4.93 2.12 2.12"></path><path d="m16.95 16.95 2.12 2.12"></path><path d="M2 12h3"></path><path d="M19 12h3"></path><path d="m4.93 19.07 2.12-2.12"></path><path d="m16.95 7.05 2.12-2.12"></path></svg>
                    </span>
                    <span>Cai dat</span>
                </a>
            </nav>
        </aside>

        <main class="page-main">
            <div class="page-wide">
                <div class="row g-4">
                    <div class="col-12 col-lg-8">
                        <section class="card mb-4">
                            <div class="card-header">
                                <h3>Account settings</h3>
                            </div>
                            <div class="card-content">
                                <form id="settings-account-form" class="vstack gap-3">
                                    <div class="form-group">
                                        <label for="settings-username">Username</label>
                                        <input id="settings-username" class="input" type="text" maxlength="100" required />
                                    </div>

                                    <div class="form-group">
                                        <label for="settings-bio">Bio</label>
                                        <textarea id="settings-bio" class="textarea" rows="4" maxlength="500"></textarea>
                                    </div>

                                    <div class="d-flex gap-2 flex-wrap">
                                        <input id="settings-avatar-file" type="file" accept="image/*" class="d-none" />
                                        <button id="settings-upload-avatar-btn" type="button" class="btn btn-outline">Upload avatar</button>
                                        <button type="submit" class="btn btn-primary ms-auto">Save account</button>
                                    </div>
                                </form>
                            </div>
                        </section>

                        <section class="card mb-4">
                            <div class="card-header">
                                <h3>Security settings</h3>
                            </div>
                            <div class="card-content">
                                <div class="mb-3">
                                    <div class="fw-semibold mb-2">Connected OAuth provider</div>
                                    <div id="settings-connected-providers" class="provider-list"></div>
                                </div>

                                <div class="d-flex flex-wrap gap-2">
                                    <a class="btn btn-outline" href="/auth/login/google">Connect Google</a>
                                </div>

                                <hr class="my-3" />

                                <div class="d-flex flex-wrap gap-2">
                                    <button id="settings-logout-all-btn" class="btn btn-danger" type="button">Logout from all devices</button>
                                </div>
                            </div>
                        </section>

                        <section class="card">
                            <div class="card-header">
                                <h3>Notification settings</h3>
                            </div>
                            <div class="card-content">
                                <div class="form-check form-switch mb-3">
                                    <input id="settings-enable-notifications" class="form-check-input" type="checkbox" />
                                    <label class="form-check-label" for="settings-enable-notifications">Enable message notifications</label>
                                </div>

                                <div class="form-check form-switch mb-3">
                                    <input id="settings-mute-conversations" class="form-check-input" type="checkbox" />
                                    <label class="form-check-label" for="settings-mute-conversations">Mute all conversations</label>
                                </div>

                                <button id="settings-save-notification-btn" class="btn btn-outline btn-sm" type="button">Save notification settings</button>
                            </div>
                        </section>
                    </div>

                    <div class="col-12 col-lg-4">
                        <section class="card h-100">
                            <div class="card-content text-center">
                                <div class="profile-avatar-wrap mx-auto mb-3">
                                    <img id="settings-avatar-preview" class="profile-avatar" src="" alt="Avatar" />
                                </div>
                                <h1 id="settings-display-name" class="h5 mb-1">Account</h1>
                                <p id="settings-display-email" class="text-muted small mb-3">-</p>
                                <div id="settings-provider-summary" class="small"></div>
                            </div>
                        </section>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<div id="toast-container" class="toast-container position-fixed top-0 end-0 p-3"></div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/fptsocial.js" asp-append-version="true"></script>
<script type="module" src="~/js/auth.js" asp-append-version="true"></script>
<script type="module" src="~/js/account-settings.js" asp-append-version="true"></script>
</body>
</html>
