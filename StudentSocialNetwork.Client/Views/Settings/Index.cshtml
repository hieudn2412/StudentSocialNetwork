@{
    ViewData["Title"] = "Settings";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account-settings.css" asp-append-version="true" />
}

<div id="account-page" class="container py-4 account-page" data-page="settings">
    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h6 mb-3">Account settings</h2>

                    <form id="settings-account-form" class="vstack gap-3">
                        <div>
                            <label class="form-label" for="settings-username">Username</label>
                            <input id="settings-username" class="form-control" type="text" maxlength="100" required />
                        </div>

                        <div>
                            <label class="form-label" for="settings-bio">Bio</label>
                            <textarea id="settings-bio" class="form-control" rows="3" maxlength="500"></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <input id="settings-avatar-file" type="file" accept="image/*" class="d-none" />
                            <button id="settings-upload-avatar-btn" type="button" class="btn btn-outline-primary">Upload avatar</button>
                            <button type="submit" class="btn btn-primary ms-auto">Save account</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h6 mb-3">Security settings</h2>

                    <div class="mb-3">
                        <div class="fw-semibold mb-2">Connected OAuth provider</div>
                        <div id="settings-connected-providers" class="provider-list"></div>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-outline-danger btn-sm" href="/auth/login/google">Connect Google</a>
                    </div>

                    <hr class="my-3" />

                    <div class="d-flex flex-wrap gap-2">
                        <button id="settings-logout-all-btn" class="btn btn-danger" type="button">Logout from all devices</button>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h6 mb-3">Notification settings</h2>

                    <div class="form-check form-switch mb-3">
                        <input id="settings-enable-notifications" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" for="settings-enable-notifications">Enable message notifications</label>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input id="settings-mute-conversations" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" for="settings-mute-conversations">Mute all conversations</label>
                    </div>

                    <button id="settings-save-notification-btn" class="btn btn-outline-primary btn-sm" type="button">Save notification settings</button>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="profile-avatar-wrap mx-auto mb-3">
                        <img id="settings-avatar-preview" class="profile-avatar" src="" alt="Avatar" />
                    </div>
                    <h1 id="settings-display-name" class="h5 mb-1">Account</h1>
                    <p id="settings-display-email" class="text-muted small mb-3">-</p>
                    <div id="settings-provider-summary" class="small"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/account-settings.js" asp-append-version="true"></script>
}
